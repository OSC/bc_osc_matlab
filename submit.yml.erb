<%-

  err_msg = "You are not a member of the matlab group. Please email oschelp@osc.edu to request access to MATLAB."
  raise(StandardError, err_msg) unless CurrentUser.group_names.include?('matlab')

  base_slurm_args = ["--nodes", "#{bc_num_slots.to_i}", "--ntasks-per-node", "#{num_cores.to_i}"]

  # Remove cluster tag, e.g. pitzer-gpu-exp to gpu-exp
  partition = global_node_type.split('-').drop(1).join('-')
  slurm_args = base_slurm_args + ["--partition", partition]

%>
---
batch_connect:
  template: vnc
script:
  <%- if gpus.to_i > 0 -%>
  gpus_per_node: <%= gpus %>
  <%- end %>
  native:
  <%- slurm_args.each do |arg| %>
  - "<%= arg %>"
  <%- end %>
